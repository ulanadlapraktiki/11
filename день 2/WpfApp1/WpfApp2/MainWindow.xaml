<Window x:Class="WpfApp2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ХранительПРО - Главное окно" Height="550" Width="900"
        WindowStartupLocation="CenterScreen" Background="#F0F0F0">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="35"/>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#2C3E50">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,10,0">
                <TextBlock x:Name="lblUser" Foreground="White" VerticalAlignment="Center" 
                           FontSize="12" Margin="0,0,10,0"/>
                <Button x:Name="btnLogout" Content="Выйти" Background="#E74C3C" 
                        Foreground="White" Width="60" Height="25" FontSize="11"
                        BorderThickness="0" Cursor="Hand"/>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="5">
            <Button x:Name="btnAdd" Content="➕ Новая заявка" Width="130" Margin="5" Padding="5"
                    Background="#27AE60" Foreground="White" BorderThickness="0" Cursor="Hand"/>
            <Button x:Name="btnEdit" Content="✏️ Редактировать" Width="120" Margin="5" Padding="5"
                    Background="#F39C12" Foreground="White" BorderThickness="0" Cursor="Hand"/>
            <Button x:Name="btnDelete" Content="🗑️ Удалить" Width="100" Margin="5" Padding="5"
                    Background="#E74C3C" Foreground="White" BorderThickness="0" Cursor="Hand"/>
            <Button x:Name="btnRefresh" Content="🔄 Обновить" Width="100" Margin="5" Padding="5"
                    Background="#3498DB" Foreground="White" BorderThickness="0" Cursor="Hand"/>
        </StackPanel>

        <DataGrid x:Name="dgvRequests" Grid.Row="2" AutoGenerateColumns="True" 
                  IsReadOnly="True" Margin="10" SelectionMode="Single" 
                  SelectionUnit="FullRow" Background="White" BorderBrush="#CCCCCC"
                  FontSize="13" RowHeight="30" AlternatingRowBackground="#F9F9F9">
            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="#34495E"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="Height" Value="35"/>
                    <Setter Property="FontSize" Value="12"/>
                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                </Style>
            </DataGrid.ColumnHeaderStyle>
        </DataGrid>
    </Grid>
</Window>