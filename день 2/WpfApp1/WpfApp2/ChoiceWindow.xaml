<Window x:Class="WpfApp2.ChoiceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Выбор типа заявки" Height="360" Width="400"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="White">

    <Border CornerRadius="10" Margin="15" BorderBrush="#CCCCCC" BorderThickness="1" Background="White">
        <StackPanel Margin="20" VerticalAlignment="Center">

            <!-- Заголовок -->
            <TextBlock Text="ХранительПРО" FontSize="20" FontWeight="Bold" 
                       Foreground="#2C3E50" HorizontalAlignment="Center" Margin="0,0,0,5"/>

            <TextBlock Text="Выберите тип заявки" FontSize="14" 
                       Foreground="#7F8C8D" HorizontalAlignment="Center" Margin="0,0,0,25"/>

            <!-- Кнопка личного посещения -->
            <Button x:Name="btnPersonal" Click="BtnPersonal_Click" 
                    Height="50" Margin="0,0,0,15" Cursor="Hand"
                    Background="#3498DB" Foreground="White" 
                    FontSize="14" FontWeight="SemiBold" BorderThickness="0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="👤 " FontSize="16"/>
                    <TextBlock Text="Личное посещение" FontSize="14"/>
                </StackPanel>
            </Button>

            <!-- Кнопка группового посещения -->
            <Button x:Name="btnGroup" Click="BtnGroup_Click" 
                    Height="50" Cursor="Hand"
                    Background="#27AE60" Foreground="White" 
                    FontSize="14" FontWeight="SemiBold" BorderThickness="0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="👥 " FontSize="16"/>
                    <TextBlock Text="Групповое посещение" FontSize="14"/>
                </StackPanel>
            </Button>

            <!-- Кнопка отмены -->
            <Button x:Name="btnCancel" Click="BtnCancel_Click" 
                    Height="35" Margin="0,15,0,0" Cursor="Hand"
                    Background="#95A5A6" Foreground="White" 
                    FontSize="12" BorderThickness="0">
                Отмена
            </Button>
        </StackPanel>
    </Border>
</Window>