<Window x:Class="WpfApp2.GroupRequestWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Групповое посещение" Height="800" Width="800"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResize"
        Background="#F5F7FA">

    <Border Background="White" CornerRadius="10" Margin="10" 
            BorderBrush="#E1E5EB" BorderThickness="1">

        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="25">

                <TextBlock Text="👥 Форма записи на групповое посещение" FontSize="20" FontWeight="Bold" 
                           Foreground="#2C3E50" Margin="0,0,0,10" HorizontalAlignment="Center"/>

                <Line X1="0" Y1="0" X2="1" Y2="0" Stretch="Fill" Stroke="#E1E5EB" Margin="0,0,0,15"/>

                <!-- Информация для пропуска -->
                <TextBlock Text="📅 Информация для пропуска" FontSize="16" FontWeight="Bold" 
                           Foreground="#2C3E50" Margin="0,0,0,15"/>

                <Border Background="#F8FAFE" CornerRadius="8" Padding="15" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="Срок действия заявки" FontSize="13" FontWeight="SemiBold" 
                                   Foreground="#34495E" Margin="0,0,0,10"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" Text="с *" VerticalAlignment="Center" 
                                       Foreground="#E74C3C" Margin="0,0,10,0"/>
                            <DatePicker x:Name="dpStartDate" Grid.Column="1" Height="32" 
                                        Margin="0,0,10,0" VerticalAlignment="Center"/>

                            <TextBlock Grid.Column="2" Text="по *" VerticalAlignment="Center" 
                                       Foreground="#E74C3C" Margin="0,0,10,0"/>
                            <DatePicker x:Name="dpEndDate" Grid.Column="3" Height="32" 
                                        VerticalAlignment="Center"/>
                        </Grid>

                        <TextBlock Text="Цель посещения *" FontSize="13" FontWeight="SemiBold" 
                                   Foreground="#34495E" Margin="0,15,0,5"/>
                        <TextBox x:Name="txtPurpose" Height="60" TextWrapping="Wrap" 
                                 AcceptsReturn="True" Padding="8" BorderBrush="#D1D9E6" BorderThickness="1"/>
                    </StackPanel>
                </Border>

                <!-- Принимающая сторона -->
                <TextBlock Text="🏢 Принимающая сторона" FontSize="16" FontWeight="Bold" 
                           Foreground="#2C3E50" Margin="0,10,0,15"/>

                <Border Background="#F8FAFE" CornerRadius="8" Padding="15" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="Подразделение *" FontSize="13" FontWeight="SemiBold" 
                                   Foreground="#34495E" Margin="0,0,0,5"/>
                        <ComboBox x:Name="cbDepartment" Height="35" Margin="0,0,0,15" 
                                  IsEditable="True" BorderBrush="#D1D9E6" BorderThickness="1"/>

                        <TextBlock Text="ФИО сотрудника *" FontSize="13" FontWeight="SemiBold" 
                                   Foreground="#34495E" Margin="0,0,0,5"/>
                        <ComboBox x:Name="cbEmployee" Height="35" BorderBrush="#D1D9E6" 
                                  BorderThickness="1" IsEditable="True"/>
                    </StackPanel>
                </Border>

                <!-- Информация об организаторе -->
                <TextBlock Text="👤 Информация об организаторе" FontSize="16" FontWeight="Bold" 
                           Foreground="#2C3E50" Margin="0,0,0,15"/>

                <Border Background="#F8FAFE" CornerRadius="8" Padding="15" Margin="0,0,0,15">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Фамилия *" 
                                   FontSize="12" Foreground="#34495E" Margin="0,0,10,5"/>
                        <TextBox x:Name="txtLastName" Grid.Row="1" Grid.Column="0" 
                                 Height="32" Margin="0,0,10,10" Padding="5"/>

                        <TextBlock Grid.Row="0" Grid.Column="1" Text="Имя *" 
                                   FontSize="12" Foreground="#34495E" Margin="0,0,10,5"/>
                        <TextBox x:Name="txtFirstName" Grid.Row="1" Grid.Column="1" 
                                 Height="32" Margin="0,0,10,10" Padding="5"/>

                        <TextBlock Grid.Row="0" Grid.Column="2" Text="Отчество" 
                                   FontSize="12" Foreground="#34495E" Margin="0,0,0,5"/>
                        <TextBox x:Name="txtPatronymic" Grid.Row="1" Grid.Column="2" 
                                 Height="32" Margin="0,0,0,10" Padding="5"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Телефон" 
                                   FontSize="12" Foreground="#34495E" Margin="0,0,10,5"/>
                        <TextBox x:Name="txtPhone" Grid.Row="3" Grid.Column="0" 
                                 Height="32" Margin="0,0,10,10" Padding="5"/>

                        <TextBlock Grid.Row="2" Grid.Column="1" Text="E-mail *" 
                                   FontSize="12" Foreground="#34495E" Margin="0,0,10,5"/>
                        <TextBox x:Name="txtEmail" Grid.Row="3" Grid.Column="1" 
                                 Height="32" Margin="0,0,10,10" Padding="5"/>

                        <TextBlock Grid.Row="2" Grid.Column="2" Text="Организация" 
                                   FontSize="12" Foreground="#34495E" Margin="0,0,0,5"/>
                        <TextBox x:Name="txtOrganization" Grid.Row="3" Grid.Column="2" 
                                 Height="32" Margin="0,0,0,10" Padding="5"/>

                        <TextBlock Grid.Row="4" Grid.ColumnSpan="3" Text="Примечание" 
                                   FontSize="12" Foreground="#34495E" Margin="0,0,0,5"/>
                        <TextBox x:Name="txtNote" Grid.Row="5" Grid.ColumnSpan="3" 
                                 Height="50" TextWrapping="Wrap" AcceptsReturn="True" 
                                 Padding="5"/>
                    </Grid>
                </Border>

                <!-- Паспортные данные организатора -->
                <Border Background="#F8FAFE" CornerRadius="8" Padding="15" Margin="0,0,0,15">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Дата рождения *" 
                                   FontSize="12" Foreground="#34495E" Margin="0,0,10,5"/>
                        <DatePicker x:Name="dpBirthDate" Grid.Row="1" Grid.Column="0" 
                                    Height="32" Margin="0,0,10,0"/>

                        <TextBlock Grid.Row="0" Grid.Column="1" Text="Серия паспорта *" 
                                   FontSize="12" Foreground="#34495E" Margin="0,0,10,5"/>
                        <TextBox x:Name="txtPassportSeries" Grid.Row="1" Grid.Column="1" 
                                 Height="32" Margin="0,0,10,0" Padding="5" MaxLength="4"/>

                        <TextBlock Grid.Row="0" Grid.Column="3" Text="Номер паспорта *" 
                                   FontSize="12" Foreground="#34495E" Margin="0,0,0,5"/>
                        <TextBox x:Name="txtPassportNumber" Grid.Row="1" Grid.Column="3" 
                                 Height="32" Padding="5" MaxLength="6"/>
                    </Grid>
                </Border>

                <!-- Список посетителей -->
                <TextBlock Text="👥 Список посетителей" FontSize="16" FontWeight="Bold" 
                           Foreground="#2C3E50" Margin="0,0,0,10"/>

                <Border Background="#F8FAFE" CornerRadius="8" Padding="15" Margin="0,0,0,15">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,15">
                            <Button x:Name="btnDownloadTemplate" Content="📥 Скачать шаблон" 
                                    Height="35" Margin="5" Background="#3498DB" Foreground="White"
                                    BorderThickness="0" Cursor="Hand"/>
                            <Button x:Name="btnUploadList" Content="📤 Загрузить список" 
                                    Height="35" Margin="5" Background="#27AE60" Foreground="White"
                                    BorderThickness="0" Cursor="Hand"/>
                            <Button x:Name="btnAddMember" Content="➕ Добавить вручную" 
                                    Height="35" Margin="5" Background="#F39C12" Foreground="White"
                                    BorderThickness="0" Cursor="Hand"/>
                        </StackPanel>

                        <DataGrid x:Name="dgvMembers" AutoGenerateColumns="False" 
                                  Height="250" Margin="0,0,0,10"
                                  BorderBrush="#D1D9E6" BorderThickness="1"
                                  Background="White" AlternatingRowBackground="#F9FAFC">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="№" Width="50" Binding="{Binding Number}"/>
                                <DataGridTextColumn Header="Фамилия и инициалы" Width="200" Binding="{Binding FullName}"/>
                                <DataGridTextColumn Header="Контакты" Width="250" Binding="{Binding Contacts}"/>
                                <DataGridTemplateColumn Header="Фото" Width="80">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button x:Name="btnUploadPhoto" Content="📷" Width="30" Height="25" 
                                                    Click="BtnUploadMemberPhoto_Click" Tag="{Binding}"
                                                    Background="#3498DB" Foreground="White" BorderThickness="0"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="Удалить" Width="60">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button x:Name="btnDelete" Content="❌" Width="30" Height="25" 
                                                    Click="BtnDeleteMember_Click" Tag="{Binding}"
                                                    Background="#E74C3C" Foreground="White" BorderThickness="0"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>

                        <TextBlock x:Name="lblMemberCount" FontSize="11" Foreground="#7F8C8D" 
                                   Text="Всего: 0 человек" TextAlignment="Right"/>
                    </StackPanel>
                </Border>

                <!-- Прикрепляемые документы -->
                <TextBlock Text="📎 Прикрепляемые документы" FontSize="16" FontWeight="Bold" 
                           Foreground="#2C3E50" Margin="0,0,0,10"/>

                <Border Background="#F8FAFE" CornerRadius="8" Padding="15" Margin="0,0,0,15">
                    <StackPanel>
                        <Button x:Name="btnUploadPassport" Content="📄 ПРИКРЕПИТЬ ФАЙЛ" 
                                Height="40" Background="#27AE60" Foreground="White"
                                BorderThickness="0" Cursor="Hand" FontSize="13"/>
                        <TextBlock x:Name="lblPassportPath" FontSize="11" Foreground="#7F8C8D" 
                                   Margin="0,5,0,0" Text="Файл не выбран" TextAlignment="Center"/>
                        <TextBlock FontSize="10" Foreground="#95A5A6" Text="(формат pdf, скан паспорта организатора)" 
                                   TextAlignment="Center" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>

                <TextBlock x:Name="lblMessage" Foreground="#E74C3C" TextAlignment="Center" 
                           FontSize="12" Margin="0,10" Height="30" TextWrapping="Wrap"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,20">
                    <Button x:Name="btnClear" Content="🗑️ Очистить форму" Width="140" Height="40" Margin="5"
                            Background="#95A5A6" Foreground="White" FontSize="13"
                            BorderThickness="0" Cursor="Hand"/>
                    <Button x:Name="btnSave" Content="✅ Оформить заявку" Width="160" Height="40" Margin="5"
                            Background="#27AE60" Foreground="White" FontSize="13" FontWeight="SemiBold"
                            BorderThickness="0" Cursor="Hand"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Border>
</Window>