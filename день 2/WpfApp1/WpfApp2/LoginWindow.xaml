<Window x:Class="WpfApp2.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ХранительПРО - Вход" Height="392" Width="380"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize">

    <Border Background="White" CornerRadius="10" Margin="15" BorderBrush="#CCCCCC" BorderThickness="1">
        <StackPanel Margin="25" VerticalAlignment="Center">

            <TextBlock Text="🔐 ХранительПРО" FontSize="20" FontWeight="Bold" 
                       Foreground="#2C3E50" Margin="0,0,0,20" HorizontalAlignment="Center"/>

            <TextBlock Text="Логин" FontSize="12" FontWeight="SemiBold" Foreground="#34495E"/>
            <TextBox x:Name="txtLogin" Height="35" FontSize="13" Padding="8,0" Margin="0,0,0,15"/>

            <TextBlock Text="Пароль" FontSize="12" FontWeight="SemiBold" Foreground="#34495E"/>
            <PasswordBox x:Name="txtPassword" Height="35" FontSize="13" Padding="8,0" Margin="0,0,0,15"/>

            <TextBlock x:Name="lblError" Foreground="Red" Margin="0,5" TextAlignment="Center" Height="25"/>

            <Button x:Name="btnLogin" Content="Войти" Height="38" Margin="0,5,0,10" 
                    Background="#2C3E50" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand"/>

            <Button x:Name="btnRegister" Content="Регистрация" Height="35" 
                    Background="#ECF0F1" Foreground="#34495E" BorderThickness="1" Cursor="Hand"/>
        </StackPanel>
    </Border>
</Window>