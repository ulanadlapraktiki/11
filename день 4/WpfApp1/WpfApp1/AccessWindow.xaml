<Window x:Class="WpfApp1.AccessWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp1"
        mc:Ignorable="d"
Title="🚪 Управление доступом" Height="400" Width="450"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">

    <Border Background="White" CornerRadius="10" Margin="10" BorderBrush="#CCCCCC" BorderThickness="1">
        <StackPanel Margin="20" VerticalAlignment="Center">

            <TextBlock Text="🚪 Управление доступом" FontSize="18" FontWeight="Bold" 
                       Foreground="#2C3E50" HorizontalAlignment="Center" Margin="0,0,0,15"/>

            <Border Background="#F8FAFE" CornerRadius="8" Padding="15" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="👤 Посетитель:" FontSize="13" FontWeight="SemiBold" Foreground="#34495E"/>
                    <TextBlock x:Name="txtVisitorName" FontSize="14" Margin="0,5,0,10" TextWrapping="Wrap"/>

                    <TextBlock Text="🕐 Время убытия (формат ЧЧ:ММ):" FontSize="13" FontWeight="SemiBold" Foreground="#34495E" Margin="0,10,0,5"/>
                    <TextBox x:Name="txtExitTime" Text="18:00" Height="35" Padding="5" MaxLength="5"/>
                </StackPanel>
            </Border>

            <Button x:Name="btnAllow" Content="✅ Разрешить доступ (открыть турникет)" 
                    Height="50" Margin="0,0,0,10" Background="#27AE60" Foreground="White" 
                    FontSize="14" FontWeight="SemiBold" BorderThickness="0" Cursor="Hand"
                    Click="BtnAllow_Click"/>

            <Button x:Name="btnClose" Content="❌ Закрыть" Height="40" 
                    Background="#95A5A6" Foreground="White" BorderThickness="0" Cursor="Hand"
                    Click="BtnClose_Click"/>

            <TextBlock x:Name="lblMessage" Foreground="Green" TextAlignment="Center" Margin="0,10,0,0" FontSize="11"/>
        </StackPanel>
    </Border>
</Window>
