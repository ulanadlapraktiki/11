<Window x:Class="WpfApp1.DepartmentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp1"
        mc:Ignorable="d"
Title="👨‍💼 Подразделение - Управление посещениями" Height="600" Width="1000"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#2C3E50" CornerRadius="8" Padding="10" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock Text="👨‍💼 Подразделение - Управление посещениями" FontSize="16" FontWeight="Bold" Foreground="White"/>
                <TextBlock x:Name="lblUser" Margin="20,0,0,0" Foreground="#BDC3C7" FontSize="12" VerticalAlignment="Center"/>
                <Button x:Name="btnLogout" Content="🚪 Выход" Margin="20,0,0,0" Background="#E74C3C" 
                        Foreground="White" BorderThickness="0" Cursor="Hand" Padding="10,5" Click="BtnLogout_Click"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Background="#F8FAFE" CornerRadius="8" Padding="10" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock Text="Дата посещения:" VerticalAlignment="Center" Margin="5"/>
                <DatePicker x:Name="dpDate" Width="120" Margin="5" SelectedDateChanged="LoadRequests"/>
                <Button x:Name="btnRefresh" Content="🔄 Обновить" Width="100" Margin="15,0,0,0" 
                        Background="#3498DB" Foreground="White" BorderThickness="0" Cursor="Hand" Click="BtnRefresh_Click"/>
            </StackPanel>
        </Border>

        <DataGrid x:Name="dgvRequests" Grid.Row="2" AutoGenerateColumns="True" 
                  SelectionMode="Single" IsReadOnly="True" Margin="0,0,0,10"
                  AlternatingRowBackground="#F9F9F9" FontSize="13"
                  MouseRightButtonUp="DgvRequests_MouseRightButtonUp">
            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="#34495E"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="Height" Value="35"/>
                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                </Style>
            </DataGrid.ColumnHeaderStyle>
        </DataGrid>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center">
            <Button x:Name="btnArrival" Content="📥 Зафиксировать прибытие" Width="200" Height="45" Margin="5"
                    Background="#F39C12" Foreground="White" FontSize="13" FontWeight="SemiBold"
                    BorderThickness="0" Cursor="Hand" Click="BtnArrival_Click"/>

            <Button x:Name="btnInfo" Content="ℹ️ Информация о заявке" Width="180" Height="45" Margin="5"
                    Background="#3498DB" Foreground="White" FontSize="13"
                    BorderThickness="0" Cursor="Hand" Click="BtnInfo_Click"/>
        </StackPanel>
    </Grid>
</Window>