<Window x:Class="WpfApp1.FormalCheckWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp1"
        mc:Ignorable="d"
Title="📋 Формальная проверка заявки" Height="500" Width="590"
        WindowStartupLocation="CenterOwner">

    <Border Background="White" CornerRadius="10" Margin="10" BorderBrush="#CCCCCC" BorderThickness="1">
        <StackPanel Margin="20">

            <TextBlock Text="📋 Формальная проверка заявки" FontSize="18" FontWeight="Bold" 
                       Foreground="#2C3E50" HorizontalAlignment="Center" Margin="0,0,0,15"/>

            <Border Background="#F8FAFE" CornerRadius="8" Padding="15" Margin="0,0,0,15">
                <StackPanel>
                    <TextBlock x:Name="txtInfo" TextWrapping="Wrap" Margin="0,0,0,10"/>
                    <TextBlock x:Name="lblBlacklistMsg" FontSize="12" FontWeight="Bold" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>

            <TextBlock Text="📅 Дата и время посещения" FontSize="14" FontWeight="Bold" Foreground="#2C3E50"/>
            <Border Background="#F8FAFE" CornerRadius="8" Padding="15" Margin="0,5,0,15">
                <StackPanel>
                    <DatePicker x:Name="dpVisitDate" Height="35" Margin="0,0,0,10"/>
                    <TextBox x:Name="txtVisitTime" Text="12:00" Height="35" Padding="5"/>
                </StackPanel>
            </Border>

            <TextBlock Text="📝 Статус" FontSize="14" FontWeight="Bold" Foreground="#2C3E50"/>
            <ComboBox x:Name="cmbStatus" Height="35" Margin="0,5,0,15">
                <ComboBoxItem>одобрена</ComboBoxItem>
                <ComboBoxItem>отклонена</ComboBoxItem>
            </ComboBox>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button x:Name="btnSave" Content="✅ Сохранить" Width="120" Height="40" Margin="5"
                        Background="#27AE60" Foreground="White" FontSize="13"
                        BorderThickness="0" Cursor="Hand" Click="BtnSave_Click"/>
                <Button x:Name="btnCancel" Content="❌ Отмена" Width="120" Height="40" Margin="5"
                        Background="#95A5A6" Foreground="White" FontSize="13"
                        BorderThickness="0" Cursor="Hand" Click="BtnCancel_Click"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>