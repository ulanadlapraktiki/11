<Window x:Class="WpfApp1.EmployeeLogin"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp1"
        mc:Ignorable="d"
Title="🛡️ ХранительПРО - Вход" Height="472" Width="518"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="#F5F7FA">

    <Border Background="White" CornerRadius="15" Margin="15" 
            BorderBrush="#E1E5EB" BorderThickness="1">

        <StackPanel Margin="25" VerticalAlignment="Center">

            <TextBlock Text="🛡️ ХранительПРО" FontSize="24" FontWeight="Bold" 
                       Foreground="#2C3E50" HorizontalAlignment="Center" Margin="0,0,0,5"/>

            <TextBlock Text="Терминалы контроля доступа" FontSize="12" 
                       Foreground="#7F8C8D" HorizontalAlignment="Center" Margin="0,0,0,25"/>

            <TextBlock Text="Код сотрудника" FontSize="13" FontWeight="SemiBold" 
                       Foreground="#34495E" Margin="0,0,0,5"/>

            <PasswordBox x:Name="txtCode" Height="40" FontSize="14" 
                         Padding="10,0" Margin="0,0,0,15"
                         BorderBrush="#D1D9E6" BorderThickness="1"
                         PasswordChar="●"/>

            <Button x:Name="btnLogin" Content="🔐 Войти" Height="45" 
                    Background="#2C3E50" Foreground="White" 
                    FontSize="14" FontWeight="SemiBold"
                    BorderThickness="0" Cursor="Hand"
                    Margin="0,5,0,10"/>

            <TextBlock x:Name="lblError" Foreground="#E74C3C" 
                       TextAlignment="Center" FontSize="12" 
                       Height="30" TextWrapping="Wrap"/>

            <Button x:Name="btnTestDB" Content="🔌 Тест БД" Height="35" Margin="0,5,0,0" 
                    Background="#3498DB" Foreground="White" BorderThickness="0" Cursor="Hand"/>

            <Border Background="#F8FAFE" CornerRadius="8" Padding="10" Margin="0,10,0,0">
                <StackPanel>
                    <TextBlock Text="ℹ️ Тестовые коды:" FontSize="11" FontWeight="SemiBold" Foreground="#34495E"/>
                    <TextBlock Text="1111 - Общий отдел" FontSize="10" Foreground="#7F8C8D"/>
                    <TextBlock Text="2222 - Охрана" FontSize="10" Foreground="#7F8C8D"/>
                    <TextBlock Text="3333 - Подразделение (IT отдел)" FontSize="10" Foreground="#7F8C8D"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </Border>
</Window>