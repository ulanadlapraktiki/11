<Window x:Class="HranitelPro.GeneralDepartmentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="👔 Общий отдел - Управление заявками" Height="700" Width="1200"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0" Background="#2C3E50" CornerRadius="8" Padding="10" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock Text="👔 Общий отдел - Формальная проверка заявок" FontSize="16" FontWeight="Bold" Foreground="White"/>
                <TextBlock x:Name="lblUser" Margin="20,0,0,0" Foreground="#BDC3C7" FontSize="12" VerticalAlignment="Center"/>
                <Button x:Name="btnLogout" Content="🚪 Выход" Margin="20,0,0,0" Background="#E74C3C" 
                        Foreground="White" BorderThickness="0" Cursor="Hand" Padding="10,5" Click="BtnLogout_Click"/>
            </StackPanel>
        </Border>

        <!-- Фильтры -->
        <Border Grid.Row="1" Background="#F8FAFE" CornerRadius="8" Padding="10" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock Text="Тип:" VerticalAlignment="Center" Margin="5"/>
                <ComboBox x:Name="cmbType" Width="100" Margin="5" SelectionChanged="ApplyFilter"/>

                <TextBlock Text="Статус:" VerticalAlignment="Center" Margin="15,0,0,5"/>
                <ComboBox x:Name="cmbStatus" Width="120" Margin="5" SelectionChanged="ApplyFilter"/>

                <TextBlock Text="Подразделение:" VerticalAlignment="Center" Margin="15,0,0,5"/>
                <ComboBox x:Name="cmbDepartment" Width="150" Margin="5" SelectionChanged="ApplyFilter"/>

                <Button x:Name="btnRefresh" Content="🔄 Обновить" Width="100" Margin="15,0,0,0" 
                        Background="#3498DB" Foreground="White" BorderThickness="0" Cursor="Hand" Click="BtnRefresh_Click"/>
            </StackPanel>
        </Border>

        <!-- Таблица заявок -->
        <DataGrid x:Name="dgvRequests" Grid.Row="2" AutoGenerateColumns="True" 
                  SelectionMode="Single" IsReadOnly="True" Margin="0,0,0,10"
                  AlternatingRowBackground="#F9F9F9" FontSize="13"
                  MouseDoubleClick="DgvRequests_MouseDoubleClick">
            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="#34495E"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="Height" Value="35"/>
                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                </Style>
            </DataGrid.ColumnHeaderStyle>
        </DataGrid>

        <!-- Кнопки действий -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,10">
            <Button x:Name="btnView" Content="🔍 Формальная проверка" Width="160" Height="40" Margin="5"
                    Background="#3498DB" Foreground="White" FontSize="13" FontWeight="SemiBold"
                    BorderThickness="0" Cursor="Hand" Click="BtnView_Click"/>

            <Button x:Name="btnReportDay" Content="📊 Отчет за день" Width="140" Height="40" Margin="5"
                    Background="#27AE60" Foreground="White" FontSize="13"
                    BorderThickness="0" Cursor="Hand" Click="BtnReportDay_Click"/>

            <Button x:Name="btnReportMonth" Content="📊 Отчет за месяц" Width="140" Height="40" Margin="5"
                    Background="#27AE60" Foreground="White" FontSize="13"
                    BorderThickness="0" Cursor="Hand" Click="BtnReportMonth_Click"/>

            <Button x:Name="btnReportYear" Content="📊 Отчет за год" Width="140" Height="40" Margin="5"
                    Background="#27AE60" Foreground="White" FontSize="13"
                    BorderThickness="0" Cursor="Hand" Click="BtnReportYear_Click"/>

            <Button x:Name="btnCurrentVisitors" Content="👥 Текущие посетители" Width="160" Height="40" Margin="5"
                    Background="#F39C12" Foreground="White" FontSize="13"
                    BorderThickness="0" Cursor="Hand" Click="BtnCurrentVisitors_Click"/>
            <Button x:Name="btnLast3Hours" Content="⏰ Отчет за 3 часа" Width="160" Height="40" Margin="5"
        Background="#9B59B6" Foreground="White" FontSize="13"
        BorderThickness="0" Cursor="Hand" Click="BtnLast3Hours_Click"/>
        </StackPanel>

        <!-- Статус бар -->
        <StatusBar Grid.Row="4" Margin="0,5,0,0">
            <StatusBarItem>
                <TextBlock x:Name="lblStatus" Foreground="Gray" FontSize="11"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>