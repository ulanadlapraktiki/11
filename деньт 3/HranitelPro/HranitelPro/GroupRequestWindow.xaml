<Window x:Class="HranitelPro.GroupRequestWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Групповая заявка" Height="750" Width="600"
        WindowStartupLocation="CenterOwner" Background="#F5F7FA" Icon="/icon.ico">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Border Background="White" CornerRadius="10" Margin="10" BorderBrush="#E1E5EB" BorderThickness="1">
            <StackPanel Margin="20">

                <TextBlock Text="👥 Групповая заявка на посещение" FontSize="18" FontWeight="Bold" 
                           Foreground="#2C3E50" Margin="0,0,0,15" HorizontalAlignment="Center"/>

                <!-- Информация для пропуска -->
                <Border Background="#F8FAFE" CornerRadius="8" Padding="12" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="📋 Информация для пропуска" FontWeight="Bold" FontSize="14" Foreground="#2C3E50"/>
                        <Grid Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Срок:" VerticalAlignment="Center" Width="60"/>
                            <TextBlock Grid.Column="1" Text="с" VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <DatePicker x:Name="dpStartDate" Grid.Column="2" Width="120"/>
                            <TextBlock Grid.Column="3" Text="по" VerticalAlignment="Center" Margin="10,0,5,0"/>
                            <DatePicker x:Name="dpEndDate" Grid.Column="4" Width="120"/>
                        </Grid>
                        <Grid Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="60"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Цель:*" VerticalAlignment="Center"/>
                            <TextBox x:Name="txtPurpose" Grid.Column="1" Height="50" TextWrapping="Wrap" AcceptsReturn="True"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Принимающая сторона -->
                <Border Background="#F8FAFE" CornerRadius="8" Padding="12" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="🏢 Принимающая сторона" FontWeight="Bold" FontSize="14" Foreground="#2C3E50"/>
                        <Grid Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Подразделение:*" VerticalAlignment="Center"/>
                            <ComboBox x:Name="cmbDepartment" Grid.Column="1" Height="30" IsEditable="True"/>
                        </Grid>
                        <Grid Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="ФИО сотрудника:*" VerticalAlignment="Center"/>
                            <ComboBox x:Name="cmbEmployee" Grid.Column="1" Height="30" IsEditable="True"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Организатор группы -->
                <Border Background="#F8FAFE" CornerRadius="8" Padding="12" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="👤 Организатор группы" FontWeight="Bold" FontSize="14" Foreground="#2C3E50"/>

                        <Grid Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Фамилия:*" VerticalAlignment="Center"/>
                            <TextBox x:Name="txtLastName" Grid.Column="1" Height="30"/>
                        </Grid>
                        <Grid Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Имя:*" VerticalAlignment="Center"/>
                            <TextBox x:Name="txtFirstName" Grid.Column="1" Height="30"/>
                        </Grid>
                        <Grid Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Отчество:" VerticalAlignment="Center"/>
                            <TextBox x:Name="txtPatronymic" Grid.Column="1" Height="30"/>
                        </Grid>
                        <Grid Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Телефон:" VerticalAlignment="Center"/>
                            <TextBox x:Name="txtPhone" Grid.Column="1" Height="30"/>
                        </Grid>
                        <Grid Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="E-mail:*" VerticalAlignment="Center"/>
                            <TextBox x:Name="txtEmail" Grid.Column="1" Height="30"/>
                        </Grid>
                        <Grid Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Организация:" VerticalAlignment="Center"/>
                            <TextBox x:Name="txtOrganization" Grid.Column="1" Height="30"/>
                        </Grid>
                        <Grid Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Примечание:" VerticalAlignment="Center"/>
                            <TextBox x:Name="txtNote" Grid.Column="1" Height="50" TextWrapping="Wrap" AcceptsReturn="True"/>
                        </Grid>
                        <Grid Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Дата рождения:*" VerticalAlignment="Center"/>
                            <DatePicker x:Name="dpBirthDate" Grid.Column="1" Height="30"/>
                        </Grid>
                        <Grid Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="100"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Паспорт:*" VerticalAlignment="Center"/>
                            <TextBox x:Name="txtPassportSeries" Grid.Column="1" Height="30" MaxLength="4" TextAlignment="Center"/>
                            <TextBlock Grid.Column="2" Text="№" VerticalAlignment="Center" Margin="5,0,5,0"/>
                            <TextBox x:Name="txtPassportNumber" Grid.Column="3" Height="30" MaxLength="6" TextAlignment="Center"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Список посетителей -->
                <Border Background="#F8FAFE" CornerRadius="8" Padding="12" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="👥 Список посетителей" FontWeight="Bold" FontSize="14" Foreground="#2C3E50"/>

                        <Button x:Name="btnAddMember" Content="➕ Добавить посетителя" Height="35" Margin="0,10,0,10"
                                Background="#3498DB" Foreground="White" BorderThickness="0" Cursor="Hand"/>

                        <DataGrid x:Name="dgvMembers" AutoGenerateColumns="False" Height="200" Margin="0,0,0,10">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="№" Width="40" Binding="{Binding Number}"/>
                                <DataGridTextColumn Header="Фамилия" Width="100" Binding="{Binding LastName}"/>
                                <DataGridTextColumn Header="Имя" Width="100" Binding="{Binding FirstName}"/>
                                <DataGridTextColumn Header="Телефон" Width="100" Binding="{Binding Phone}"/>
                                <DataGridTextColumn Header="Email" Width="150" Binding="{Binding Email}"/>
                                <DataGridTemplateColumn Header="Удалить" Width="50">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="❌" Width="30" Height="25" Click="RemoveMember_Click" Tag="{Binding}"
                                                    Background="#E74C3C" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>

                        <TextBlock x:Name="lblMemberCount" FontSize="11" Foreground="#7F8C8D" Text="Всего: 0 человек"/>
                    </StackPanel>
                </Border>

                <TextBlock x:Name="lblStatus" Foreground="Red" TextAlignment="Center" Margin="0,5" Height="30"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                    <Button x:Name="btnSubmit" Content="✅ Отправить заявку" Height="40" Width="160" Margin="5"
                            Background="#27AE60" Foreground="White" FontWeight="SemiBold" BorderThickness="0" Cursor="Hand"/>
                    <Button x:Name="btnCancel" Content="❌ Отмена" Height="40" Width="100" Margin="5"
                            Background="#E74C3C" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </ScrollViewer>
</Window>