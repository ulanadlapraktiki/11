<Window x:Class="HranitelPro.ReportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="📊 Статистический отчет" Height="500" Width="700"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#2C3E50" CornerRadius="8" Padding="10" Margin="0,0,0,10">
            <TextBlock x:Name="lblTitle" FontSize="16" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
        </Border>

        <Border Grid.Row="1" Background="#F8FAFE" CornerRadius="8" Padding="10" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button x:Name="btnSaveReport" Content="💾 Сохранить отчет" Width="140" Height="35" Margin="5"
                        Background="#27AE60" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                <Button x:Name="btnSaveAuto" Content="📁 Сохранить в Отчеты ТБ" Width="180" Height="35" Margin="5"
                        Background="#F39C12" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                <Button x:Name="btnClose" Content="❌ Закрыть" Width="100" Height="35" Margin="5"
                        Background="#95A5A6" Foreground="White" BorderThickness="0" Cursor="Hand"/>
            </StackPanel>
        </Border>

        <!-- Таблица отчета -->
        <DataGrid x:Name="dgvReport" Grid.Row="2" AutoGenerateColumns="True" 
                  IsReadOnly="True" Margin="0,0,0,10"
                  AlternatingRowBackground="#F9F9F9" FontSize="13">
            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="#34495E"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="Height" Value="35"/>
                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                </Style>
            </DataGrid.ColumnHeaderStyle>
        </DataGrid>

        <TextBlock x:Name="lblTotal" Grid.Row="3" TextAlignment="Center" FontSize="12" Foreground="Gray" Margin="0,5"/>
    </Grid>
</Window>