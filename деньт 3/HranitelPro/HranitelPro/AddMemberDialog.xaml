<Window x:Class="HranitelPro.AddMemberDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Добавление посетителя" Height="454" Width="400"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">

    <Border Background="White" CornerRadius="10" Margin="10" BorderBrush="#CCCCCC" BorderThickness="1">
        <StackPanel Margin="20">
            <TextBlock Text="➕ Добавление посетителя" FontSize="16" FontWeight="Bold" 
                       Foreground="#2C3E50" HorizontalAlignment="Center" Margin="0,0,0,15"/>

            <TextBlock Text="Фамилия *" FontSize="12" Foreground="#34495E"/>
            <TextBox x:Name="txtLastName" Height="30" Margin="0,5,0,10"/>

            <TextBlock Text="Имя *" FontSize="12" Foreground="#34495E"/>
            <TextBox x:Name="txtFirstName" Height="30" Margin="0,5,0,10"/>

            <TextBlock Text="Телефон" FontSize="12" Foreground="#34495E"/>
            <TextBox x:Name="txtPhone" Height="30" Margin="0,5,0,10"/>

            <TextBlock Text="Email *" FontSize="12" Foreground="#34495E"/>
            <TextBox x:Name="txtEmail" Height="30" Margin="0,5,0,15"/>

            <TextBlock x:Name="lblError" Foreground="Red" FontSize="11" Height="25"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button x:Name="btnSave" Content="✅ Добавить" Width="100" Height="35" Margin="5"
                        Background="#27AE60" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                <Button x:Name="btnCancel" Content="❌ Отмена" Width="100" Height="35" Margin="5"
                        Background="#95A5A6" Foreground="White" BorderThickness="0" Cursor="Hand"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>