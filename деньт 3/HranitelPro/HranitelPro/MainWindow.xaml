<Window x:Class="HranitelPro.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ХранительПРО - Главное окно" Height="550" Width="900">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="45"/>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Верхняя панель -->
        <Border Grid.Row="0" Background="#2C3E50">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,15,0">
                <Border Background="#34495E" CornerRadius="15" Padding="10,5" Margin="0,0,10,0">
                    <TextBlock x:Name="lblUser" Foreground="#ECF0F1" FontSize="12" VerticalAlignment="Center"/>
                </Border>
                <Button x:Name="btnLogout" Content="🚪 Выйти" Background="#E74C3C" Foreground="White" 
                        Width="70" Height="30" BorderThickness="0" Cursor="Hand" Margin="5,0,0,0"/>
            </StackPanel>
        </Border>

        <!-- Кнопки управления -->
        <Border Grid.Row="1" Background="White" BorderBrush="#E1E5EB" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="5">
                <Button x:Name="btnAdd" Content="➕ Личная заявка" Width="140" Height="38" Margin="5"
                        Background="#27AE60" Foreground="White" FontWeight="SemiBold" BorderThickness="0" Cursor="Hand"/>
                <Button x:Name="btnGroupAdd" Content="👥 Групповая заявка" Width="150" Height="38" Margin="5"
                        Background="#2980B9" Foreground="White" FontWeight="SemiBold" BorderThickness="0" Cursor="Hand"/>
                <Button x:Name="btnEdit" Content="✏️ Редактировать" Width="140" Height="38" Margin="5"
                        Background="#F39C12" Foreground="White" FontWeight="SemiBold" BorderThickness="0" Cursor="Hand"/>
                <Button x:Name="btnDelete" Content="🗑️ Удалить" Width="120" Height="38" Margin="5"
                        Background="#E74C3C" Foreground="White" FontWeight="SemiBold" BorderThickness="0" Cursor="Hand"/>
                <Button x:Name="btnRefresh" Content="🔄 Обновить" Width="100" Height="38" Margin="5"
                        Background="#3498DB" Foreground="White" FontWeight="SemiBold" BorderThickness="0" Cursor="Hand"/>
            </StackPanel>
        </Border>

        <!-- Таблица заявок -->
        <Border Grid.Row="2" Background="White" Margin="10" CornerRadius="8" BorderBrush="#E1E5EB" BorderThickness="1">
            <DataGrid x:Name="dgvRequests" AutoGenerateColumns="True" IsReadOnly="True" 
                      SelectionMode="Single" SelectionUnit="FullRow" Margin="0"
                      BorderThickness="0" Background="White" FontSize="13" RowHeight="35"
                      AlternatingRowBackground="#F9FAFC">
                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#34495E"/>
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="Height" Value="40"/>
                        <Setter Property="FontSize" Value="13"/>
                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#4A90E2"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>
            </DataGrid>
        </Border>
    </Grid>
</Window>