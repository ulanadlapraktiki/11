<Window x:Class="HranitelPro.FormalCheckWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="📋 Формальная проверка заявки" Height="736" Width="600"
        WindowStartupLocation="CenterOwner">

    <Border Background="White" CornerRadius="10" Margin="10" BorderBrush="#CCCCCC" BorderThickness="1">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="20">

                <TextBlock Text="📋 Формальная проверка заявки" FontSize="18" FontWeight="Bold" 
                           Foreground="#2C3E50" HorizontalAlignment="Center" Margin="0,0,0,15"/>

                <!-- Информация о заявке -->
                <Border Background="#F8FAFE" CornerRadius="8" Padding="15" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock x:Name="txtInfo" TextWrapping="Wrap" Margin="0,0,0,10" FontSize="13"/>
                        <TextBlock x:Name="lblBlacklistMsg" FontSize="13" FontWeight="Bold" Margin="0,10,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Прикрепленные файлы -->
                <TextBlock Text="📎 Прикрепленные файлы" FontSize="14" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,10"/>
                <ListBox x:Name="lbFiles" Height="100" Margin="0,0,0,15" Background="#F8FAFE"/>

                <!-- Дата и время -->
                <TextBlock Text="📅 Дата и время посещения" FontSize="14" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,10"/>
                <Border Background="#F8FAFE" CornerRadius="8" Padding="15" Margin="0,0,0,15">
                    <StackPanel>
                        <DatePicker x:Name="dpVisitDate" Height="35" Margin="0,0,0,10"/>
                        <TextBox x:Name="txtVisitTime" Text="12:00" Height="35" Padding="5"/>
                        <TextBlock Text="Формат времени: ЧЧ:ММ" FontSize="10" Foreground="Gray" Margin="5,2,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Статус -->
                <TextBlock Text="📝 Статус" FontSize="14" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,10"/>
                <ComboBox x:Name="cmbStatus" Height="35" Margin="0,0,0,15">
                    <ComboBoxItem>одобрена</ComboBoxItem>
                    <ComboBoxItem>отклонена</ComboBoxItem>
                </ComboBox>

                <!-- Сообщение об ошибке -->
                <TextBlock x:Name="lblError" Foreground="#E74C3C" TextAlignment="Center" Margin="0,10" Height="30" TextWrapping="Wrap"/>

                <!-- Кнопки -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                    <Button x:Name="btnSave" Content="✅ Сохранить" Width="120" Height="40" Margin="5"
                            Background="#27AE60" Foreground="White" FontSize="13" FontWeight="SemiBold"
                            BorderThickness="0" Cursor="Hand"/>
                    <Button x:Name="btnCancel" Content="❌ Отмена" Width="120" Height="40" Margin="5"
                            Background="#95A5A6" Foreground="White" FontSize="13"
                            BorderThickness="0" Cursor="Hand"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Border>
</Window>