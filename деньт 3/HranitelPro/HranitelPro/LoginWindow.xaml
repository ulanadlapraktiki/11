<Window x:Class="HranitelPro.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ХранительПРО - Вход" Height="835" Width="420"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize">

    <Border Background="White" CornerRadius="15" Margin="15" 
            BorderBrush="#E1E5EB" BorderThickness="1">

        <StackPanel Margin="25" VerticalAlignment="Center">

            <TextBlock Text="🛡️ ХранительПРО" FontSize="24" FontWeight="Bold" 
                       Foreground="#2C3E50" HorizontalAlignment="Center" Margin="0,0,0,5"/>

            <TextBlock Text="Система управления заявками" FontSize="12" 
                       Foreground="#7F8C8D" HorizontalAlignment="Center" Margin="0,0,0,25"/>

            <!-- Разделитель -->
            <Border Height="2" Background="#E1E5EB" Margin="0,5,0,15" CornerRadius="1"/>

            <TextBlock Text="👤 Вход для посетителя" FontSize="14" FontWeight="Bold" 
                       Foreground="#2C3E50" HorizontalAlignment="Center" Margin="0,0,0,10"/>

            <TextBlock Text="Логин" FontSize="13" FontWeight="SemiBold" Foreground="#34495E" Margin="0,0,0,5"/>
            <TextBox x:Name="txtLogin" Height="40" FontSize="14" Padding="10,0" Margin="0,0,0,10"
                     BorderBrush="#D1D9E6" BorderThickness="1" Background="#F8FAFE"/>

            <TextBlock Text="Пароль" FontSize="13" FontWeight="SemiBold" Foreground="#34495E" Margin="0,0,0,5"/>
            <PasswordBox x:Name="txtPassword" Height="40" FontSize="14" Padding="10,0" Margin="0,0,0,10"
                         BorderBrush="#D1D9E6" BorderThickness="1" Background="#F8FAFE" PasswordChar="●"/>

            <Button x:Name="btnLogin" Content="🔐 Войти как посетитель" Height="45" Margin="0,5,0,10"
                    Background="#27AE60" Foreground="White" FontSize="14" FontWeight="SemiBold" 
                    BorderThickness="0" Cursor="Hand"/>

            <!-- Разделитель -->
            <Border Height="1" Background="#E1E5EB" Margin="0,15,0,15" CornerRadius="1"/>

            <TextBlock Text="👔 Вход для сотрудника" FontSize="14" FontWeight="Bold" 
                       Foreground="#2C3E50" HorizontalAlignment="Center" Margin="0,0,0,10"/>

            <TextBlock Text="Код сотрудника" FontSize="13" FontWeight="SemiBold" Foreground="#34495E" Margin="0,0,0,5"/>
            <PasswordBox x:Name="txtEmployeeCode" Height="40" FontSize="14" Padding="10,0" Margin="0,0,0,10"
                         BorderBrush="#D1D9E6" BorderThickness="1" Background="#F8FAFE" PasswordChar="●"/>

            <Button x:Name="btnEmployeeLogin" Content="👔 Войти как сотрудник" Height="45" Margin="0,5,0,10"
                    Background="#2C3E50" Foreground="White" FontSize="14" FontWeight="SemiBold" 
                    BorderThickness="0" Cursor="Hand"/>

            <Button x:Name="btnRegister" Content="📝 Регистрация" Height="40" Margin="0,5,0,0"
                    Background="#ECF0F1" Foreground="#34495E" FontSize="13"
                    BorderThickness="1" BorderBrush="#BDC3C7" Cursor="Hand"/>

            <TextBlock x:Name="lblError" Foreground="#E74C3C" Margin="0,10" TextAlignment="Center" 
                       FontSize="12" Height="30" TextWrapping="Wrap"/>

            <Border Background="#F8FAFE" CornerRadius="8" Padding="10" Margin="0,5,0,0">
                <StackPanel>
                    <TextBlock Text="ℹ️ Тестовые данные:" FontSize="11" FontWeight="SemiBold" Foreground="#34495E"/>
                    <TextBlock Text="Посетитель: admin / admin" FontSize="10" Foreground="#7F8C8D"/>
                    <TextBlock Text="Сотрудник: код 1111 (общий отдел)" FontSize="10" Foreground="#7F8C8D"/>
                    <TextBlock Text="Сотрудник: код 2222 (охрана)" FontSize="10" Foreground="#7F8C8D"/>
                    <TextBlock Text="Сотрудник: код 3333 (подразделение)" FontSize="10" Foreground="#7F8C8D"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </Border>
</Window>